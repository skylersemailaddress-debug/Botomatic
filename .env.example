# =============================================================================
# Botomatic Orchestrator API — Environment Variables
# Copy this file to .env and fill in your values before starting.
# Lines marked [REQUIRED] must be set. Lines marked [OPTIONAL] have defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime mode
# -----------------------------------------------------------------------------
# [REQUIRED] Set to "commercial" for production. "development" uses in-memory DB.
RUNTIME_MODE=commercial

# [REQUIRED for commercial] Set to "durable" to use Supabase. "memory" for dev only.
PROJECT_REPOSITORY_MODE=durable

# -----------------------------------------------------------------------------
# AI — Anthropic
# -----------------------------------------------------------------------------
# [REQUIRED] Your Anthropic API key.
ANTHROPIC_API_KEY=sk-ant-...

# [OPTIONAL] Model overrides. Defaults shown.
# NEXUS_MODEL_FLAGSHIP_PROVIDER=anthropic
# NEXUS_MODEL_FLAGSHIP=claude-opus-4-7
# NEXUS_MODEL_GENERAL_PROVIDER=anthropic
# NEXUS_MODEL_GENERAL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Database — Supabase
# -----------------------------------------------------------------------------
# [REQUIRED for commercial] Your Supabase project URL and service role key.
# Run supabase/migrations/001_init.sql in your Supabase SQL editor first.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# [OPTIONAL] Job queue backend. "supabase" for multi-worker. "memory" for dev.
# QUEUE_BACKEND=supabase
# QUEUE_LEASE_MS=30000
# QUEUE_POLL_INTERVAL_MS=2000
# WORKER_CONCURRENCY=2

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Option A: OIDC (Auth0 or compatible provider) — recommended for commercial
# OIDC_ISSUER_URL=https://your-tenant.us.auth0.com/
# OIDC_CLIENT_ID=your_client_id
# OIDC_AUDIENCE=https://your-api-identifier

# Option B: Static bearer token — simpler, fine for private beta
# [REQUIRED if not using OIDC] A strong random secret.
API_AUTH_TOKEN=replace_with_a_strong_random_secret

# [REQUIRED for commercial] Password to access the control-plane UI.
# If unset, the UI is open to anyone — only acceptable for local dev.
# Defaults to API_AUTH_TOKEN if not separately set.
BOTOMATIC_UI_PASSWORD=replace_with_a_strong_random_secret

# [REQUIRED for commercial] Server-side token for control-plane → API calls.
# Must NOT use NEXT_PUBLIC_ prefix. Matches API_AUTH_TOKEN on the orchestrator.
BOTOMATIC_API_TOKEN=replace_with_a_strong_random_secret

# -----------------------------------------------------------------------------
# GitHub integration (for project intake and automated PRs)
# -----------------------------------------------------------------------------
# [REQUIRED for GitHub intake and git lifecycle]
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-github-org-or-username
GITHUB_REPO=your-repo-name

# [OPTIONAL] Set by CI automatically — records the deployed commit SHA in health check.
# GITHUB_SHA=

# -----------------------------------------------------------------------------
# Executor
# -----------------------------------------------------------------------------
# [OPTIONAL] "claude" uses the real claude-runner sidecar (calls Anthropic API).
# "mock" simulates builds without making API calls. Default: mock.
EXECUTOR=claude

# [OPTIONAL] claude-runner sidecar URL. Defaults shown.
# CLAUDE_EXECUTOR_URL=http://127.0.0.1:4000
# CLAUDE_EXECUTOR_KEY=

# [OPTIONAL] Set to "true" if claude-runner is managed externally (e.g. separate Railway service).
# EXTERNAL_CLAUDE_RUNNER=false

# [OPTIONAL] Timeout for a single executor call in milliseconds. Default: 300000 (5 minutes).
# EXECUTOR_TIMEOUT_MS=300000

# -----------------------------------------------------------------------------
# Multi-provider model router (claude-runner)
# -----------------------------------------------------------------------------
# The executor automatically routes packets to the best provider for the task:
#
#   Task type      Primary            Secondary          Tertiary
#   ─────────────  ─────────────────  ─────────────────  ─────────────────
#   reasoning      Gemini 2.5 Pro     OpenAI o3-mini     Claude Sonnet
#   brainstorm     GPT-4o             Gemini 2.5 Flash   Claude Sonnet
#   code_complex   Claude Sonnet      Deepseek V3        GPT-4o
#   code_simple    Deepseek V3        Gemini 2.5 Flash   GPT-4o-mini
#   utility        Llama 3.3 (Groq)   GPT-4o-mini        Gemini 2.5 Flash
#
# Providers are skipped automatically if their key is absent. Add any subset.
# Only ANTHROPIC_API_KEY is required for a working system.

# [OPTIONAL] Anthropic — code generation, structure, implementation
# CLAUDE_RUNNER_MODEL=claude-sonnet-4-6      # code_complex primary
# CLAUDE_POWER_MODEL=claude-opus-4-7         # optional upgrade

# [OPTIONAL] OpenAI — brainstorming, design, reasoning
# OPENAI_API_KEY=sk-...
# OPENAI_BRAINSTORM_MODEL=gpt-4o             # brainstorm primary
# OPENAI_REASON_MODEL=o3-mini               # reasoning secondary
# OPENAI_FAST_MODEL=gpt-4o-mini             # utility secondary

# [OPTIONAL] Google Gemini — architecture reasoning, fast execution
# GOOGLE_AI_API_KEY=AIza...
# GEMINI_PRO_MODEL=gemini-2.5-pro           # reasoning primary
# GEMINI_FLASH_MODEL=gemini-2.5-flash       # brainstorm secondary, code_simple secondary

# [OPTIONAL] Groq — ultra-fast Llama inference for utility/doc tasks
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile        # utility primary

# [OPTIONAL] Deepseek — exceptional code quality at very low cost
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat              # code_simple primary, code_complex secondary

# -----------------------------------------------------------------------------
# CORS — required when UI and API are on different domains
# -----------------------------------------------------------------------------
# [REQUIRED for production] Comma-separated list of allowed UI origins.
# Example: https://botomatic.vercel.app,https://app.botomatic.dev
ALLOWED_ORIGINS=https://your-ui-domain.vercel.app

# -----------------------------------------------------------------------------
# Rate limiting — /operator/send
# -----------------------------------------------------------------------------
# [OPTIONAL] Max requests per actor per window. Defaults shown.
# OPERATOR_RATE_LIMIT_MAX=20
# OPERATOR_RATE_LIMIT_WINDOW_MS=60000

# [OPTIONAL] Request timeout limits by route class. Defaults shown.
# ROUTE_TIMEOUT_SHORT_MS=10000
# ROUTE_TIMEOUT_MEDIUM_MS=60000
# ROUTE_TIMEOUT_LONG_MS=300000

# [OPTIONAL] Max JSON body size for API requests. Default: 10mb.
# BODY_SIZE_LIMIT_MB=10

# -----------------------------------------------------------------------------
# File upload / intake
# -----------------------------------------------------------------------------
# [OPTIONAL] Defaults shown.
# BOTOMATIC_UPLOAD_DIR=./runtime/uploads
# BOTOMATIC_MAX_UPLOAD_MB=250
# BOTOMATIC_MAX_EXTRACTED_MB=2000
# BOTOMATIC_MAX_ZIP_FILES=20000

# -----------------------------------------------------------------------------
# Alerts & observability
# -----------------------------------------------------------------------------
# [OPTIONAL] Slack or compatible webhook for route error and packet failure alerts.
SLACK_WEBHOOK_URL=replace_at_runtime
BOTOMATIC_ALERT_WEBHOOK_URL=replace_at_runtime

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# [OPTIONAL] Port for the orchestrator API. Default: 3000.
# PORT=3000

# [OPTIONAL] Worker instance ID. Auto-generated if not set.
# WORKER_ID=worker_01

# -----------------------------------------------------------------------------
# Control Plane (Next.js UI) — set these in apps/control-plane/.env.local
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
