NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
BOTOMATIC_ALERT_WEBHOOK_URL=replace_at_runtime
SLACK_WEBHOOK_URL=replace_at_runtime

# ── Code Generation Executor ──────────────────────────────────────────────────
# Set EXECUTOR=claude to enable real AI-driven code generation.
# Without this, the system uses a static boilerplate fallback.
EXECUTOR=claude

# URL of the claude-runner service (apps/claude-runner).
# Start it with: npm run executor:dev
CLAUDE_EXECUTOR_URL=http://127.0.0.1:4000

# Your Anthropic API key — required by claude-runner for real generation.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── GitHub (optional — enables real git push per wave) ────────────────────────
GITHUB_TOKEN=replace_at_runtime

# ── Deployment targets (optional) ────────────────────────────────────────────
VERCEL_TOKEN=replace_at_runtime
RAILWAY_TOKEN=replace_at_runtime
