NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# ── Core executor ─────────────────────────────────────────────────────────────
# Set EXECUTOR=claude to enable real AI-driven code generation.
EXECUTOR=replace_at_runtime
CLAUDE_EXECUTOR_URL=replace_at_runtime

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=replace_at_runtime

# ── OpenAI (utility tier — fast/cheap for repo_layout, validation, generic) ───
OPENAI_API_KEY=replace_at_runtime

# ── Gemini (optional) ────────────────────────────────────────────────────────
GEMINI_API_KEY=replace_at_runtime

# ── Azure OpenAI (optional) ──────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=replace_at_runtime
AZURE_OPENAI_ENDPOINT=replace_at_runtime

# ── Model routing ─────────────────────────────────────────────────────────────
# Three tiers: flagship (deep reasoning), general (standard), utility (fast/cheap).
# Flagship: auth, spec_compiler, governance_security, repair_replay, truth_memory
NEXUS_MODEL_FLAGSHIP_PROVIDER=replace_at_runtime
NEXUS_MODEL_FLAGSHIP=replace_at_runtime
# General: api_schema, intelligence_shell, deployment_rollback, execution_runtime
NEXUS_MODEL_GENERAL_PROVIDER=replace_at_runtime
NEXUS_MODEL_GENERAL=replace_at_runtime
# Utility: repo_layout, validation_proof, generic
NEXUS_MODEL_UTILITY_PROVIDER=replace_at_runtime
NEXUS_MODEL_UTILITY=replace_at_runtime

# Feature flags
NEXUS_CONVERSATION_MODEL_ENABLED=replace_at_runtime
NEXUS_COUNCIL_MODEL_ENABLED=replace_at_runtime

# ── Auth0 / OIDC ──────────────────────────────────────────────────────────────
OIDC_ISSUER_URL=replace_at_runtime
AUTH0_CLIENT_SECRET=replace_at_runtime

# ── Slack alerts ──────────────────────────────────────────────────────────────
BOTOMATIC_ALERT_WEBHOOK_URL=replace_at_runtime
SLACK_WEBHOOK_URL=replace_at_runtime

# ── GitHub (enables real git push per wave) ──────────────────────────────────
GITHUB_TOKEN=replace_at_runtime

# ── Deployment targets ────────────────────────────────────────────────────────
VERCEL_TOKEN=replace_at_runtime
RAILWAY_TOKEN=replace_at_runtime
