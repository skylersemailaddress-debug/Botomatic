{
  "workspaces": [
    "apps/control-plane",
    "apps/orchestrator-api"
  ],
  "scripts": {
    "build": "npm run ui:build",
    "api:start": "PORT=3001 tsx apps/orchestrator-api/src/bootstrap.ts",
    "api:dev": "PORT=3001 tsx apps/orchestrator-api/src/bootstrap.ts",
    "ui:dev": "npm --prefix apps/control-plane run dev",
    "ui:build": "npm --prefix apps/control-plane run build",
    "ui:start": "npm --prefix apps/control-plane run start",
    "control-plane:dev": "concurrently \"npm run api:dev\" \"npm run ui:dev\"",
    "validate:all": "tsx packages/validation/src/cli.ts",
    "validate:behavioral": "tsx packages/validation/src/runtime/cli.ts",
    "validate:observability": "tsx packages/validation/src/runtime/opsObservability.ts",
    "benchmark:builder": "tsx packages/validation/src/runtime/builderQualityBenchmark.ts",
    "proof:greenfield": "tsx packages/validation/src/runtime/proofGreenfield.ts",
    "proof:dirty-repo": "tsx packages/validation/src/runtime/proofDirtyRepo.ts",
    "proof:self-upgrade": "tsx packages/validation/src/runtime/proofSelfUpgrade.ts",
    "proof:universal-pipeline": "tsx packages/validation/src/runtime/proofUniversalPipeline.ts",
    "proof:multi-domain-emitted-output": "tsx packages/validation/src/runtime/proofMultiDomainEmittedOutput.ts",
    "proof:domain-runtime-commands": "tsx packages/validation/src/runtime/proofDomainRuntimeCommands.ts",
    "proof:external-deployment-readiness": "tsx packages/validation/src/runtime/proofExternalDeploymentReadiness.ts",
    "proof:deployment-dry-run": "tsx packages/validation/src/runtime/proofDeploymentDryRun.ts",
    "proof:credentialed-deployment-readiness": "tsx packages/validation/src/runtime/proofCredentialedDeploymentReadiness.ts",
    "proof:live-deployment-execution-readiness": "tsx packages/validation/src/runtime/proofLiveDeploymentExecutionReadiness.ts",
    "proof:secrets-credential-management": "tsx packages/validation/src/runtime/proofSecretsCredentialManagement.ts",
    "proof:all": "tsx packages/validation/src/runtime/proofAll.ts",
    "test:spec-engine": "tsx packages/spec-engine/src/tests/specEngine.test.ts",
    "test:build-contract": "tsx packages/spec-engine/src/tests/buildContract.test.ts",
    "test:blueprints": "tsx packages/blueprints/src/tests/registry.test.ts",
    "test:domain-builders": "tsx packages/domain-builders/src/tests/registry.test.ts",
    "test:proof-engine": "tsx packages/proof-engine/src/tests/claimVerifier.test.ts",
    "test:self-upgrade": "tsx packages/self-upgrade-engine/src/tests/selfUpgrade.test.ts",
    "test:no-placeholder": "tsx packages/validation/src/generatedApp/tests/noPlaceholder.test.ts",
    "test:universal": "npm run -s test:spec-engine && npm run -s test:build-contract && npm run -s test:blueprints && npm run -s test:domain-builders && npm run -s test:proof-engine && npm run -s test:self-upgrade && npm run -s test:no-placeholder"
  },
  "dependencies": {
    "@trigger.dev/sdk": "^4.4.4"
  },
  "devDependencies": {
    "@trigger.dev/build": "^4.4.4",
    "concurrently": "^9.0.1",
    "tsx": "^4.19.2"
  }
}